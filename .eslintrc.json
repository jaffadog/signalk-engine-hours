{
  "extends": ["airbnb-base", "prettier"],
  "ignorePatterns": ["public/**"],
  "overrides": [
    {
      "files": ["test/**/*.js"],
      "env": {
        "mocha": true
      },
      "plugins": ["mocha"],
      "rules": {
        "no-unused-expressions": "off",
        "func-names": "off",
        "prefer-arrow-callback": "off",
        "no-shadow": "off",
        "max-len": "off",
        "prefer-destructuring": "off",
        "no-promise-executor-return": "off"
      }
    }
  ]
}
